# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=100

# Claude model
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Provider selection (anthropic/ollama for LLM, openai/ollama for embeddings)
# Set both to "ollama" for fully local mode — no API keys needed
LLM_PROVIDER_TYPE=anthropic
EMBEDDING_PROVIDER_TYPE=openai

# Ollama (local models — used when provider type is "ollama")
OLLAMA_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_EMBED_DIMENSIONS=768

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_docs

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# DuckDB
DUCKDB_PATH=./data/analytics.duckdb

# RAG parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=10
SIMILARITY_THRESHOLD=0.7

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
